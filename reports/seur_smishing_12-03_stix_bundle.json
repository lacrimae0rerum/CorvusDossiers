    {
      "type": "campaign",
      "spec_version": "2.1",
      "id": "campaign--b2c3d4e5-6789-4fab-0123-456789abcdef",
      "created": "2026-03-12T00:00:00.000Z",
      "modified": "2026-03-12T00:00:00.000Z",
      "name": "Smishing SEUR - SMISH-SEUR-2026-0312",
      "description": "Campaña de smishing (phishing por SMS) que suplanta a la empresa de mensajería SEUR (Grupo Geopost/DPD) para capturar datos personales, credenciales de tarjetas de pago y códigos OTP/3DS. Utiliza el kit de phishing k468 desplegado en el dominio seurtjm.cv (ccTLD de Cabo Verde).",
      "first_seen": "2026-03-12T00:00:00.000Z",
      "lang": "es"
    },
    {
      "type": "infrastructure",
      "spec_version": "2.1",
      "id": "infrastructure--c3d4e5f6-7890-4abc-1234-567890abcdef",
      "created": "2026-03-12T00:00:00.000Z",
      "modified": "2026-03-12T00:00:00.000Z",
      "name": "Infraestructura de phishing seurtjm.cv",
      "description": "Infraestructura del sitio de phishing que incluye dominio seurtjm.cv (.cv = Cabo Verde), IP 50.114.184.241 (Ace Data Centers / IPXO LLC), nameservers ns1/ns2.dyna-ns.net (Dynadot), panel de administración en /CNIXMQnPlR/, API de exfiltración y canal WebSocket C2 bidireccional.",
      "infrastructure_types": [
        "hosting"
      ],
      "lang": "es"
    },
    {
      "type": "tool",
      "spec_version": "2.1",
      "id": "tool--e5f6a7b8-9012-4cde-3456-7890abcdef01",
      "created": "2026-03-12T00:00:00.000Z",
      "modified": "2026-03-12T00:00:00.000Z",
      "name": "Kit de Phishing k468",
      "description": "Kit de phishing como servicio (PhaaS) identificado como k468_es_post_seur_index. Construido con Vue.js y Axios. Implementa flujo multi-etapa: captura de datos personales, datos de tarjeta bancaria, interceptación de OTP/3DS, y canal WebSocket para control en tiempo real por el operador. Soporta redes VISA, Mastercard, AMEX, Discover, JCB, Maestro y MIR.",
      "tool_types": [
        "exploitation"
      ],
      "lang": "es"
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--a1234567-8901-4bcd-ef23-456789abcde0",
      "created": "2026-03-12T00:00:00.000Z",
      "modified": "2026-03-12T00:00:00.000Z",
      "name": "Phishing: Spearphishing Link",
      "description": "Envío de SMS fraudulentos (smishing) con enlace al dominio seurtjm.cv que redirige a una réplica del sitio web de SEUR para engañar a la víctima.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1566.002",
          "url": "https://attack.mitre.org/techniques/T1566/002/"
        }
      ],
      "lang": "es"
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--b2345678-9012-4cde-f034-56789abcdef1",
      "created": "2026-03-12T00:00:00.000Z",
      "modified": "2026-03-12T00:00:00.000Z",
      "name": "Input Capture: Web Portal Capture",
      "description": "Captura de credenciales, datos personales y financieros mediante formularios web fraudulentos que replican la interfaz de SEUR. Incluye captura de números de tarjeta, CVV, fecha de caducidad y códigos OTP.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1056.003",
          "url": "https://attack.mitre.org/techniques/T1056/003/"
        }
      ],
      "lang": "es"
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--c3456789-0123-4def-a145-6789abcdef02",
      "created": "2026-03-12T00:00:00.000Z",
      "modified": "2026-03-12T00:00:00.000Z",
      "name": "Adversary-in-the-Middle",
      "description": "Interceptación en tiempo real de códigos OTP/3DS mediante canal WebSocket bidireccional (wss://seurtjm.cv/ws). El operador actúa como intermediario entre la víctima y la entidad bancaria, retransmitiendo códigos de verificación en tiempo real.",
      "external_references": [
        {
          "source_name": "mitre-attack",
          "external_id": "T1557",
          "url": "https://attack.mitre.org/techniques/T1557/"
        }
      ],
      "lang": "es"
    },
    {
      "type": "attack-pattern",
      "spec_version": "2.1",
      "id": "attack-pattern--d4567890-1234-4ef0-b256-789abcdef013",
      "created": "2026-03-12T00:00:00.000Z",
      "modified": "2026-03-12T00:00:00.000Z",
      "name": "Financial Theft",
      "description": "Objetivo final de la campaña: robo financiero mediante el uso fraudulento de datos de tarjetas bancarias y códigos de autenticación capturados a las víctimas.",
