    {
      "type": "campaign",
      "spec_version": "2.1",
      "id": "campaign--netflix-smishing-2026",
      "created": "2026-03-09T00:00:00.000Z",
      "modified": "2026-03-09T00:00:00.000Z",
      "name": "Netflix Smishing Campaign Q1 2026",
      "description": "Active smishing campaign impersonating Netflix billing via SMS. 7-stage credential harvesting flow: login → billing → PII → credit card → PIN → 3D Secure approval → OTP. Real-time 3DS fraud enables immediate financial theft. Cross-brand kit reuse confirmed on healthcare domain (espace-sante-dossier.com). Peak activity January 2026 with 15+ domains registered.",
      "first_seen": "2025-11-28T00:00:00.000Z",
      "last_seen": "2026-03-09T00:00:00.000Z",
      "aliases": ["THREAT-2026-SMISH-001"]
    },

